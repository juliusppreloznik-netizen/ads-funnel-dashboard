        // ═══════════════════════════════════════════════════════════════════════
        // FUNCTIONS
        // ═══════════════════════════════════════════════════════════════════════

        // Panel switching
        function showPanel(panel) {
            document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.panel-content').forEach(p => p.classList.remove('active'));
            document.querySelector(`.panel-tab[onclick="showPanel('${panel}')"]`).classList.add('active');
            document.getElementById(`${panel}-panel`).classList.add('active');
        }

        // Color mode state
        let colorMode = 'text'; // 'text' or 'bg'

        // Set color mode
        function setColorMode(mode) {
            colorMode = mode;
            document.getElementById('colorModeText').classList.toggle('active', mode === 'text');
            document.getElementById('colorModeBg').classList.toggle('active', mode === 'bg');
        }

        // Apply color based on current mode
        function applySelectedColor(color) {
            const selected = editor.getSelected();
            if (selected) {
                if (colorMode === 'text') {
                    selected.addStyle({ color: color });
                    showStatus(`✓ Text color: ${color}`);
                } else {
                    selected.addStyle({ 'background-color': color });
                    showStatus(`✓ Background: ${color}`);
                }
            } else {
                showStatus('⚠️ Select an element first');
            }
        }

        // Apply color to selected element
        function applyColor(color) {
            const selected = editor.getSelected();
            if (selected) {
                selected.addStyle({ color: color });
                showStatus(`✓ Applied ${color}`);
            } else {
                showStatus('⚠️ Select an element first');
            }
        }

        // Apply background color to selected element
        function applyBgColor(color) {
            const selected = editor.getSelected();
            if (selected) {
                selected.addStyle({ 'background-color': color });
                showStatus(`✓ Applied background ${color}`);
            } else {
                showStatus('⚠️ Select an element first');
            }
        }

        // Device switching
        function setDevice(device) {
            editor.setDevice(device);
            document.querySelectorAll('.device-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
        }

        // Load Modal
        function openLoadModal() { document.getElementById('loadModal').classList.add('active'); }
        function closeLoadModal() { document.getElementById('loadModal').classList.remove('active'); }

        // Export Modal
        function openExportModal() {
            let html = editor.getHtml();
            
            // Create a temporary DOM to manipulate
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = html;
            
            // Remove all editor-only elements first
            const editorOnlyElements = tempDiv.querySelectorAll('[data-editor-only]');
            editorOnlyElements.forEach(function(el) {
                el.remove();
            });
            
            // Find all custom code blocks and replace their content with stored code
            const codeBlocks = tempDiv.querySelectorAll('[data-code-id]');
            codeBlocks.forEach(function(block) {
                const blockId = block.getAttribute('data-code-id');
                if (blockId && customCodeStorage[blockId]) {
                    block.innerHTML = customCodeStorage[blockId];
                }
            });
            
            // Also find blocks by class and replace
            const placeholders = tempDiv.querySelectorAll('.custom-code-block');
            placeholders.forEach(function(block) {
                const blockId = block.getAttribute('data-code-id');
                if (blockId && customCodeStorage[blockId]) {
                    block.innerHTML = customCodeStorage[blockId];
                }
            });
            
            html = tempDiv.innerHTML;
            
            // Generate modal HTML and JS for survey buttons
            let modalHTML = '';
            let modalJS = '';
            
            for (const [btnId, embedCode] of Object.entries(buttonEmbedStorage)) {
                if (embedCode) {
                    // Sanitize btnId for use in function names (replace dashes with underscores)
                    const safeBtnId = btnId.replace(/-/g, '_');
                    
                    modalHTML += '\n    <!-- Survey Modal for ' + btnId + ' -->\n    <div id="surveyModal_' + safeBtnId + '" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:99999;align-items:center;justify-content:center;padding:20px;overflow-y:auto;">\n        <div style="background:#0a0a0a;border:1px solid #222;border-radius:16px;max-width:650px;width:100%;min-height:500px;position:relative;margin:auto;">\n            <button onclick="closeSurveyModal_' + safeBtnId + '()" style="position:absolute;top:10px;right:10px;background:#222;border:none;color:#fff;font-size:20px;cursor:pointer;z-index:10;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;">&times;</button>\n            <div style="padding:50px 20px 20px 20px;min-height:480px;">' + embedCode + '</div>\n        </div>\n    </div>';
                    
                    modalJS += '\n    function openSurveyModal_' + safeBtnId + '() { document.getElementById("surveyModal_' + safeBtnId + '").style.display = "flex"; document.body.style.overflow = "hidden"; }\n    function closeSurveyModal_' + safeBtnId + '() { document.getElementById("surveyModal_' + safeBtnId + '").style.display = "none"; document.body.style.overflow = ""; }';
                }
            }
            
            // Add click handlers to buttons with data-btn-id
            let buttonClickJS = '\n    document.addEventListener("DOMContentLoaded", function() {';
            for (const [btnId, embedCode] of Object.entries(buttonEmbedStorage)) {
                if (embedCode) {
                    const safeBtnId = btnId.replace(/-/g, '_');
                    buttonClickJS += '\n        document.querySelectorAll(\'[data-btn-id="' + btnId + '"]\').forEach(function(btn) { btn.addEventListener("click", function(e) { e.preventDefault(); openSurveyModal_' + safeBtnId + '(); }); });';
                }
            }
            buttonClickJS += '\n    });';
            
            // Use the stored CSS (preserves all properties) + any new styles from editor
            const editorCss = editor.getCss();
            const css = loadedCSS || editorCss;
            const baseCSS = 'html,body{margin:0;padding:0;background:#0a0a0a;color:#fff;font-family:"Inter",sans-serif;}*{box-sizing:border-box;}[id^="surveyModal_"] iframe{width:100%!important;min-height:450px!important;border:none!important;}';
            
            let fullCode = '<!DOCTYPE html>\n<html lang="en">\n<head>\n    <meta charset="UTF-8">\n    <meta name="viewport" content="width=device-width, initial-scale=1.0">\n    <title>Landing Page</title>\n    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">\n    <style>\n' + baseCSS + '\n' + css + '\n    </style>\n</head>\n<body>\n' + html + modalHTML;
            
            if (modalJS) {
                fullCode += '\n<scr' + 'ipt>' + modalJS + buttonClickJS + '\n</scr' + 'ipt>';
            }
            
            fullCode += '\n</body>\n</html>';
            
            document.getElementById('exportCode').value = fullCode;
            document.getElementById('exportModal').classList.add('active');
        }
        function closeExportModal() { document.getElementById('exportModal').classList.remove('active'); }

        // Load code
        function loadCode() {
            const code = document.getElementById('loadCode').value.trim();
            if (!code) { alert('Paste HTML first'); return; }

            let html = '', css = '';
            const styleMatch = code.match(/<style[^>]*>([\s\S]*?)<\/style>/gi);
            if (styleMatch) css = styleMatch.map(m => m.match(/<style[^>]*>([\s\S]*?)<\/style>/i)?.[1] || '').join('\n');
            const bodyMatch = code.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
            html = bodyMatch ? bodyMatch[1].trim() : code;

            // Store CSS globally for export
            loadedCSS = css;

            // Clear editor
            editor.DomComponents.clear();
            editor.CssComposer.clear();
            
            // Set HTML components
            editor.setComponents(html);

            // Function to inject CSS into iframe
            function injectCSS() {
                const frame = editor.Canvas.getFrameEl();
                if (frame && frame.contentDocument) {
                    const doc = frame.contentDocument;
                    
                    // Set background
                    doc.documentElement.style.background = '#0a0a0a';
                    doc.body.style.background = '#0a0a0a';
                    doc.body.style.margin = '0';
                    doc.body.style.padding = '0';
                    
                    // Remove any existing injected style
                    const existingStyle = doc.getElementById('injected-styles');
                    if (existingStyle) existingStyle.remove();
                    
                    // Create and inject style element with FULL CSS
                    const styleEl = doc.createElement('style');
                    styleEl.id = 'injected-styles';
                    styleEl.textContent = css;
                    doc.head.appendChild(styleEl);
                    
                    return true;
                }
                return false;
            }

            // Try multiple times to ensure CSS is injected
            injectCSS();
            setTimeout(injectCSS, 50);
            setTimeout(injectCSS, 150);
            setTimeout(injectCSS, 300);

            closeLoadModal();
            document.getElementById('loadCode').value = '';
            showStatus('✓ Loaded!');
        }

        // Preview
        function previewPage() {
            let html = editor.getHtml();
            const css = loadedCSS || editor.getCss();
            
            // Create a temporary DOM to manipulate
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = html;
            
            // Remove all editor-only elements first
            const editorOnlyElements = tempDiv.querySelectorAll('[data-editor-only]');
            editorOnlyElements.forEach(function(el) {
                el.remove();
            });
            
            // Find all custom code blocks and replace their content with stored code
            const codeBlocks = tempDiv.querySelectorAll('[data-code-id]');
            codeBlocks.forEach(function(block) {
                const blockId = block.getAttribute('data-code-id');
                if (blockId && customCodeStorage[blockId]) {
                    block.innerHTML = customCodeStorage[blockId];
                }
            });
            
            // Also find blocks by class and replace
            const placeholders = tempDiv.querySelectorAll('.custom-code-block');
            placeholders.forEach(function(block) {
                const blockId = block.getAttribute('data-code-id');
                if (blockId && customCodeStorage[blockId]) {
                    block.innerHTML = customCodeStorage[blockId];
                }
            });
            
            html = tempDiv.innerHTML;
            
            // Generate modal HTML and JS for survey buttons
            let modalHTML = '';
            let modalJS = '';
            
            for (const [btnId, embedCode] of Object.entries(buttonEmbedStorage)) {
                if (embedCode) {
                    // Sanitize btnId for use in function names (replace dashes with underscores)
                    const safeBtnId = btnId.replace(/-/g, '_');
                    
                    modalHTML += '<div id="surveyModal_' + safeBtnId + '" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:99999;align-items:center;justify-content:center;padding:20px;overflow-y:auto;"><div style="background:#0a0a0a;border:1px solid #222;border-radius:16px;max-width:650px;width:100%;min-height:500px;position:relative;margin:auto;"><button onclick="closeSurveyModal_' + safeBtnId + '()" style="position:absolute;top:10px;right:10px;background:#222;border:none;color:#fff;font-size:20px;cursor:pointer;z-index:10;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;">&times;</button><div style="padding:50px 20px 20px 20px;min-height:480px;">' + embedCode + '</div></div></div>';
                    
                    modalJS += 'function openSurveyModal_' + safeBtnId + '(){document.getElementById("surveyModal_' + safeBtnId + '").style.display="flex";document.body.style.overflow="hidden";}function closeSurveyModal_' + safeBtnId + '(){document.getElementById("surveyModal_' + safeBtnId + '").style.display="none";document.body.style.overflow="";}';
                }
            }
            
            // Add click handlers to buttons with data-btn-id (since onclick attributes may not export)
            let buttonClickJS = 'document.addEventListener("DOMContentLoaded",function(){';
            for (const [btnId, embedCode] of Object.entries(buttonEmbedStorage)) {
                if (embedCode) {
                    const safeBtnId = btnId.replace(/-/g, '_');
                    buttonClickJS += "document.querySelectorAll('[data-btn-id=\"" + btnId + "\"]').forEach(function(btn){btn.addEventListener('click',function(e){e.preventDefault();openSurveyModal_" + safeBtnId + "();});});";
                }
            }
            buttonClickJS += '});';
            
            // Add base styles - ensure proper layout and iframe styling
            const baseCSS = 'html,body{margin:0;padding:0;background:#0a0a0a;color:#fff;font-family:"Inter",sans-serif;}*{box-sizing:border-box;}[id^="surveyModal_"] iframe{width:100%!important;min-height:450px!important;border:none!important;}';
            
            const win = window.open('', '_blank');
            let previewHTML = '<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"><style>' + baseCSS + css + '</style></head><body>' + html + modalHTML;
            if (modalJS) {
                previewHTML += '<scr' + 'ipt>' + modalJS + buttonClickJS + '</scr' + 'ipt>';
            }
            previewHTML += '</body></html>';
            win.document.write(previewHTML);
            win.document.close();
        }

        // Copy
        function copyCode() {
            document.getElementById('exportCode').select();
            document.execCommand('copy');
            showStatus('✓ Copied!');
        }

        // Download
        function downloadFile() {
            const code = document.getElementById('exportCode').value;
            const blob = new Blob([code], { type: 'text/html' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'landing-page.html';
            a.click();
        }

        // Status
        function showStatus(msg) {
            const s = document.getElementById('statusBar');
            s.textContent = msg;
            s.classList.add('show');
            setTimeout(() => s.classList.remove('show'), 2000);
        }

        // Function to inject stored CSS into canvas
        function reinjectCSS() {
            if (!loadedCSS) return;
            const frame = editor.Canvas.getFrameEl();
            if (frame && frame.contentDocument) {
                const doc = frame.contentDocument;
                doc.documentElement.style.background = '#0a0a0a';
                doc.body.style.background = '#0a0a0a';
                
                // Check if our style exists
                let styleEl = doc.getElementById('injected-styles');
                if (!styleEl) {
                    styleEl = doc.createElement('style');
                    styleEl.id = 'injected-styles';
                    doc.head.appendChild(styleEl);
                }
                styleEl.textContent = loadedCSS;
            }
        }

        // Refresh styles manually
        function refreshStyles() {
            if (!loadedCSS) {
                showStatus('⚠️ No styles to refresh - load a page first');
                return;
            }
            reinjectCSS();
            showStatus('✓ Styles refreshed!');
        }

        // Keyboard
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { closeLoadModal(); closeExportModal(); closeTemplatesModal(); }
        });

        // Force canvas to show black background on load
        editor.on('load', () => {
            const frame = editor.Canvas.getFrameEl();
            if (frame && frame.contentDocument) {
                const doc = frame.contentDocument;
                if (doc.documentElement) {
                    doc.documentElement.style.background = '#0a0a0a';
                }
                if (doc.body) {
                    doc.body.style.background = '#0a0a0a';
                    doc.body.style.minHeight = '100vh';
                }
            }
            reinjectCSS();
        });

        // Re-inject CSS on canvas render
        editor.on('canvas:frame:load', reinjectCSS);

        // Also update canvas on component changes
        editor.on('component:add', () => {
            setTimeout(() => {
                const frame = editor.Canvas.getFrameEl();
                if (frame && frame.contentDocument && frame.contentDocument.body) {
                    frame.contentDocument.body.style.background = '#0a0a0a';
                    frame.contentDocument.documentElement.style.background = '#0a0a0a';
                }
                reinjectCSS();
            }, 50);
        });

