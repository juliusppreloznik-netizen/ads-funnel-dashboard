<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Funnel Builder</title>
    <link href="https://unpkg.com/grapesjs@0.21.10/dist/css/grapes.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: #0a0a0a; color: #fff; overflow: hidden; }

        /* ═══════════════════════════════════════════════════════════════════════
           TOP BAR
           ═══════════════════════════════════════════════════════════════════════ */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 16px;
            background: #000;
            border-bottom: 1px solid #1a1a1a;
            height: 50px;
            z-index: 100;
        }
        .top-left { display: flex; align-items: center; gap: 20px; }
        .logo { font-size: 14px; font-weight: 700; }
        .logo span { color: #dc2626; }
        
        .device-btns { display: flex; gap: 4px; }
        .device-btn {
            background: #111;
            border: 1px solid #222;
            color: #666;
            padding: 6px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }
        .device-btn:hover, .device-btn.active { background: #1a1a1a; color: #fff; border-color: #333; }
        
        .top-center { display: flex; gap: 4px; }
        .tool-btn {
            background: #111;
            border: 1px solid #222;
            color: #888;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 500;
            transition: all 0.2s;
        }
        .tool-btn:hover { background: #1a1a1a; color: #fff; border-color: #333; }
        
        .top-right { display: flex; gap: 8px; }
        .btn {
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
        }
        .btn-dark { background: #1a1a1a; color: #fff; border: 1px solid #333; }
        .btn-dark:hover { background: #222; }
        .btn-red { background: #dc2626; color: #fff; }
        .btn-red:hover { background: #b91c1c; }

        /* ═══════════════════════════════════════════════════════════════════════
           MAIN LAYOUT
           ═══════════════════════════════════════════════════════════════════════ */
        .editor-container {
            display: flex;
            height: calc(100vh - 50px);
        }

        /* Left Panel - Blocks */
        .panel-left {
            width: 240px;
            background: #0a0a0a;
            border-right: 1px solid #1a1a1a;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .panel-header {
            padding: 12px 16px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #666;
            border-bottom: 1px solid #1a1a1a;
            background: #080808;
        }
        .blocks-container {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
        }
        .block-category {
            margin-bottom: 16px;
        }
        .block-category-title {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #dc2626;
            margin-bottom: 8px;
            padding-left: 4px;
        }
        .blocks-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        /* Editor Canvas */
        #gjs {
            flex: 1;
            height: 100%;
            overflow: hidden;
        }

        /* Right Panel - Styles */
        .panel-right {
            width: 260px;
            background: #0a0a0a;
            border-left: 1px solid #1a1a1a;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .panel-tabs {
            display: flex;
            border-bottom: 1px solid #1a1a1a;
            background: #080808;
        }
        .panel-tab {
            flex: 1;
            padding: 10px;
            font-size: 11px;
            font-weight: 600;
            text-align: center;
            color: #666;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
        }
        .panel-tab:hover { color: #999; }
        .panel-tab.active { color: #dc2626; border-bottom-color: #dc2626; }
        .panel-content {
            flex: 1;
            overflow-y: auto;
            display: none;
        }
        .panel-content.active { display: block; }

        /* ═══════════════════════════════════════════════════════════════════════
           GRAPESJS OVERRIDES
           ═══════════════════════════════════════════════════════════════════════ */
        .gjs-one-bg { background: #0a0a0a !important; }
        .gjs-two-color { color: #fff !important; }
        .gjs-three-bg { background: #111 !important; }
        .gjs-four-color, .gjs-four-color-h:hover { color: #dc2626 !important; }

        /* Canvas - FORCE BLACK BACKGROUND */
        .gjs-cv-canvas {
            background: #0a0a0a !important;
            top: 0;
            width: 100%;
            height: 100%;
        }
        .gjs-cv-canvas__frames { background: #0a0a0a !important; }
        .gjs-frame-wrapper { background: #0a0a0a !important; }
        .gjs-frame { background: #0a0a0a !important; }

        /* Hide default panels */
        .gjs-pn-panels { display: none !important; }
        .gjs-pn-views-container { display: none !important; }

        /* Selected/Hovered elements */
        .gjs-selected { outline: 2px solid #dc2626 !important; outline-offset: -2px; }
        .gjs-hovered { outline: 1px dashed rgba(220,38,38,0.5) !important; }

        /* Toolbar */
        .gjs-toolbar {
            background: #111 !important;
            border: 1px solid #333 !important;
            border-radius: 6px !important;
        }
        .gjs-toolbar-item { color: #fff !important; padding: 5px 7px !important; }
        .gjs-toolbar-item:hover { color: #dc2626 !important; }

        /* Badge */
        .gjs-badge {
            background: #dc2626 !important;
            color: #fff !important;
            font-size: 9px !important;
            padding: 2px 6px !important;
            border-radius: 3px !important;
        }

        /* Resizer */
        .gjs-resizer-h {
            border: 2px solid #dc2626 !important;
            border-radius: 50% !important;
            width: 10px !important;
            height: 10px !important;
            background: #0a0a0a !important;
        }

        /* RTE */
        .gjs-rte-toolbar {
            background: #111 !important;
            border: 1px solid #333 !important;
            border-radius: 6px !important;
        }
        .gjs-rte-action { color: #fff !important; }
        .gjs-rte-action:hover { color: #dc2626 !important; }

        /* Blocks in left panel */
        .gjs-block {
            background: #111 !important;
            border: 1px solid #222 !important;
            border-radius: 6px !important;
            padding: 12px 8px !important;
            min-height: auto !important;
            width: 100% !important;
            margin: 0 !important;
            transition: all 0.2s !important;
        }
        .gjs-block:hover {
            border-color: #dc2626 !important;
            background: #1a1a1a !important;
        }
        .gjs-block__media { margin-bottom: 6px !important; }
        .gjs-block__media svg { fill: #666 !important; width: 28px !important; height: 28px !important; }
        .gjs-block:hover .gjs-block__media svg { fill: #dc2626 !important; }
        .gjs-block-label {
            font-size: 10px !important;
            color: #888 !important;
            font-weight: 500 !important;
        }
        .gjs-block:hover .gjs-block-label { color: #fff !important; }

        /* Style Manager */
        .gjs-sm-sector {
            border-bottom: 1px solid #1a1a1a !important;
        }
        .gjs-sm-sector-title {
            background: #080808 !important;
            border: none !important;
            color: #888 !important;
            font-size: 11px !important;
            font-weight: 600 !important;
            padding: 12px 16px !important;
        }
        .gjs-sm-sector-title:hover { color: #fff !important; }
        .gjs-sm-properties { padding: 12px 16px !important; background: #0a0a0a !important; }
        .gjs-sm-property { margin-bottom: 12px !important; }
        .gjs-sm-label { color: #666 !important; font-size: 11px !important; margin-bottom: 6px !important; }
        .gjs-field {
            background: #111 !important;
            border: 1px solid #222 !important;
            border-radius: 4px !important;
            color: #fff !important;
        }
        .gjs-field:focus-within { border-color: #dc2626 !important; }
        .gjs-field input { color: #fff !important; }
        .gjs-field-arrow-u, .gjs-field-arrow-d { border-top-color: #666 !important; border-bottom-color: #666 !important; }

        /* Color Picker */
        .gjs-field-color-picker {
            background: #111 !important;
            border: 1px solid #222 !important;
            border-radius: 4px !important;
        }

        /* Color Swatches Panel */
        .color-swatches {
            padding: 12px 16px;
            border-bottom: 1px solid #1a1a1a;
        }
        .color-swatches-title {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #666;
            margin-bottom: 10px;
        }
        .color-swatches-grid {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 6px;
        }
        .color-swatch {
            width: 100%;
            aspect-ratio: 1;
            border-radius: 4px;
            cursor: pointer;
            border: 1px solid #333;
            transition: all 0.2s;
        }
        .color-swatch:hover {
            transform: scale(1.15);
            border-color: #fff;
            box-shadow: 0 0 8px rgba(255,255,255,0.3);
        }
        .color-mode-btn {
            background: #111;
            border: 1px solid #222;
            color: #666;
            font-size: 10px;
            font-weight: 600;
            padding: 4px 8px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .color-mode-btn:hover { color: #fff; border-color: #333; }
        .color-mode-btn.active { background: #dc2626; color: #fff; border-color: #dc2626; }

        /* Radio/Checkbox */
        .gjs-radio-item { background: #111 !important; border: 1px solid #222 !important; color: #888 !important; }
        .gjs-radio-item:hover { color: #fff !important; }
        .gjs-radio-item-focused { background: #dc2626 !important; color: #fff !important; border-color: #dc2626 !important; }

        /* Layer Manager */
        .gjs-layer {
            background: #0a0a0a !important;
            color: #888 !important;
            font-size: 12px !important;
        }
        .gjs-layer:hover { background: #111 !important; color: #fff !important; }
        .gjs-layer-selected { background: #1a1a1a !important; color: #fff !important; }
        .gjs-layer-title { padding: 8px 12px !important; }
        .gjs-layer-caret { border-left-color: #666 !important; }
        .gjs-layer-vis { color: #666 !important; }
        .gjs-layer-vis:hover { color: #dc2626 !important; }

        /* Trait Manager */
        .gjs-trt-trait {
            padding: 8px 0 !important;
            border-bottom: 1px solid #1a1a1a !important;
        }
        .gjs-trt-trait__wrp-label { color: #666 !important; font-size: 11px !important; }

        /* ═══════════════════════════════════════════════════════════════════════
           MODALS
           ═══════════════════════════════════════════════════════════════════════ */
        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
            z-index: 9999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .modal.active { display: flex; }
        .modal-box {
            background: #111;
            border: 1px solid #222;
            border-radius: 12px;
            width: 100%;
            max-width: 900px;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid #222;
        }
        .modal-header h3 { font-size: 16px; font-weight: 600; }
        .modal-close {
            background: none;
            border: none;
            color: #666;
            font-size: 24px;
            cursor: pointer;
        }
        .modal-close:hover { color: #fff; }
        .modal-body { padding: 20px; flex: 1; overflow: auto; }
        .modal-body textarea {
            width: 100%;
            height: 400px;
            background: #0a0a0a;
            border: 1px solid #222;
            border-radius: 8px;
            color: #ccc;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 11px;
            padding: 16px;
            resize: none;
            line-height: 1.5;
        }
        .modal-body textarea:focus { outline: none; border-color: #dc2626; }
        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 16px 20px;
            border-top: 1px solid #222;
        }
        .modal-hint {
            background: rgba(220,38,38,0.1);
            border: 1px solid rgba(220,38,38,0.3);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 16px;
            font-size: 12px;
            color: #ccc;
            line-height: 1.6;
        }

        /* Status */
        .status-bar {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: #22c55e;
            color: #000;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            z-index: 1000;
            display: none;
        }
        .status-bar.show { display: block; }

        /* Code Editor Modal */
        .code-editor-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
            z-index: 99999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .code-editor-modal.active { display: flex; }
        .code-editor-box {
            background: #111;
            border: 1px solid #222;
            border-radius: 12px;
            width: 100%;
            max-width: 800px;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
        }
        .code-editor-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            border-bottom: 1px solid #222;
        }
        .code-editor-header h3 { font-size: 16px; font-weight: 600; margin: 0; }
        .code-editor-close {
            background: none;
            border: none;
            color: #666;
            font-size: 24px;
            cursor: pointer;
            line-height: 1;
        }
        .code-editor-close:hover { color: #fff; }
        .code-editor-body { padding: 20px; flex: 1; overflow: auto; }
        .code-editor-body textarea {
            width: 100%;
            height: 350px;
            background: #0a0a0a;
            border: 1px solid #222;
            border-radius: 8px;
            color: #ccc;
            font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
            font-size: 12px;
            padding: 16px;
            resize: none;
            line-height: 1.5;
        }
        .code-editor-body textarea:focus { outline: none; border-color: #dc2626; }
        .code-editor-hint {
            background: rgba(220,38,38,0.1);
            border: 1px solid rgba(220,38,38,0.3);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 16px;
            font-size: 13px;
            color: #a1a1aa;
        }
        .code-editor-footer {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 16px 20px;
            border-top: 1px solid #222;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #0a0a0a; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #444; }

        /* Templates Button */
        .btn-templates {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: #fff;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
        }
        .btn-templates:hover { opacity: 0.9; }

        /* Templates Modal */
        .templates-modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.9);
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .templates-modal.active { display: flex; }
        .templates-box {
            background: #111;
            border: 1px solid #333;
            border-radius: 16px;
            width: 100%;
            max-width: 500px;
            overflow: hidden;
        }
        .templates-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid #222;
        }
        .templates-header h3 { margin: 0; font-size: 18px; }
        .templates-body { padding: 20px; }
        .template-card {
            background: #0a0a0a;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .template-card:hover { border-color: #f59e0b; background: #111; }
        .template-card h4 { margin: 0 0 8px 0; font-size: 16px; }
        .template-card p { margin: 0; font-size: 13px; color: #888; line-height: 1.5; }
        .template-card-icon { font-size: 32px; margin-bottom: 12px; }

        /* AI Assistant Button */
        .btn-ai {
            background: linear-gradient(135deg, #8b5cf6, #6366f1);
            color: #fff;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
        }
        .btn-ai:hover { opacity: 0.9; transform: scale(1.02); }

        /* AI Panel */
        .ai-panel {
            position: fixed;
            right: -380px;
            top: 50px;
            width: 380px;
            height: calc(100vh - 50px);
            background: #0a0a0a;
            border-left: 1px solid #222;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: right 0.3s ease;
        }
        .ai-panel.active { right: 0; }
        .ai-panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            background: linear-gradient(135deg, #8b5cf6, #6366f1);
            color: #fff;
        }
        .ai-panel-header h3 { font-size: 14px; font-weight: 600; margin: 0; }
        .ai-panel-close {
            background: rgba(255,255,255,0.2);
            border: none;
            color: #fff;
            width: 28px;
            height: 28px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
        }
        .ai-panel-close:hover { background: rgba(255,255,255,0.3); }
        
        /* Prompt Generator Body */
        .prompt-gen-body {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }
        .prompt-intro {
            font-size: 12px;
            color: #888;
            margin-bottom: 16px;
            line-height: 1.5;
        }
        .prompt-section {
            margin-bottom: 20px;
        }
        .prompt-section-title {
            font-size: 11px;
            font-weight: 700;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 10px;
        }
        .prompt-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }
        .prompt-btn {
            background: #111;
            border: 1px solid #333;
            color: #ccc;
            padding: 12px 10px;
            border-radius: 8px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        .prompt-btn:hover {
            background: #1a1a1a;
            border-color: #8b5cf6;
            color: #fff;
        }
        .custom-prompt-input {
            width: 100%;
            background: #111;
            border: 1px solid #333;
            border-radius: 8px;
            color: #fff;
            padding: 12px;
            font-size: 12px;
            font-family: inherit;
            resize: none;
            height: 70px;
            margin-bottom: 10px;
        }
        .custom-prompt-input:focus { outline: none; border-color: #8b5cf6; }
        .custom-prompt-input::placeholder { color: #555; }
        .prompt-btn-full {
            width: 100%;
            background: linear-gradient(135deg, #8b5cf6, #6366f1);
            border: none;
            color: #fff;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .prompt-btn-full:hover { opacity: 0.9; }
        
        /* Prompt Output Area */
        .prompt-output-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 16px;
            overflow: hidden;
        }
        .prompt-output-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            font-size: 12px;
            color: #888;
        }
        .prompt-back-btn {
            background: #222;
            border: 1px solid #333;
            color: #888;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 11px;
            cursor: pointer;
        }
        .prompt-back-btn:hover { color: #fff; border-color: #444; }
        .prompt-output {
            flex: 1;
            background: #111;
            border: 1px solid #333;
            border-radius: 8px;
            color: #ccc;
            padding: 12px;
            font-size: 11px;
            font-family: 'Monaco', 'Menlo', monospace;
            line-height: 1.5;
            resize: none;
            margin-bottom: 12px;
        }
        .prompt-output:focus { outline: none; }
        .copy-prompt-btn {
            background: linear-gradient(135deg, #22c55e, #16a34a);
            border: none;
            color: #fff;
            padding: 14px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .copy-prompt-btn:hover { opacity: 0.9; }

        /* ═══════════════════════════════════════════════════════════════════════
           FUNNEL GENERATOR MODAL
           ═══════════════════════════════════════════════════════════════════════ */
        .funnel-gen-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .funnel-gen-modal.active { display: flex; }
        .funnel-gen-box {
            background: #111;
            border: 1px solid #333;
            border-radius: 16px;
            width: 100%;
            max-width: 600px;
            overflow: hidden;
        }
        .funnel-gen-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 24px;
            background: linear-gradient(135deg, #10B981, #059669);
            color: #fff;
        }
        .funnel-gen-header h3 { margin: 0; font-size: 18px; font-weight: 700; }
        .funnel-gen-body { padding: 24px; }
        
        .fg-section { margin-bottom: 24px; }
        .fg-section:last-child { margin-bottom: 0; }
        .fg-label {
            font-size: 12px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 10px;
            display: block;
        }
        .fg-input {
            width: 100%;
            background: #0a0a0a;
            border: 1px solid #333;
            border-radius: 8px;
            color: #fff;
            padding: 14px 16px;
            font-size: 14px;
            font-family: inherit;
        }
        .fg-input:focus { outline: none; border-color: #10B981; }
        .fg-input::placeholder { color: #555; }
        .fg-textarea {
            height: 100px;
            resize: none;
        }
        
        /* Color Picker Grid */
        .fg-color-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 10px;
        }
        .fg-color-option {
            aspect-ratio: 1;
            border-radius: 10px;
            cursor: pointer;
            border: 3px solid transparent;
            transition: all 0.2s;
            position: relative;
        }
        .fg-color-option:hover { transform: scale(1.1); }
        .fg-color-option.selected { border-color: #fff; box-shadow: 0 0 15px rgba(255,255,255,0.3); }
        .fg-color-option::after {
            content: '✓';
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
            opacity: 0;
            transition: opacity 0.2s;
        }
        .fg-color-option.selected::after { opacity: 1; }
        
        /* Page Type Buttons */
        .fg-page-btns {
            display: flex;
            gap: 10px;
        }
        .fg-page-btn {
            flex: 1;
            background: #0a0a0a;
            border: 2px solid #333;
            border-radius: 10px;
            padding: 16px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        .fg-page-btn:hover { border-color: #555; }
        .fg-page-btn.selected { border-color: #10B981; background: rgba(16,185,129,0.1); }
        .fg-page-btn-icon { font-size: 28px; margin-bottom: 8px; }
        .fg-page-btn-label { font-size: 13px; font-weight: 600; color: #fff; }
        
        .fg-generate-btn {
            width: 100%;
            background: linear-gradient(135deg, #10B981, #059669);
            border: none;
            color: #fff;
            padding: 16px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 24px;
        }
        .fg-generate-btn:hover { opacity: 0.9; transform: translateY(-2px); }
        .fg-generate-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
        
        .fg-api-row {
            display: flex;
            gap: 10px;
            align-items: center;
        }
        .fg-api-input {
            flex: 1;
        }
        .fg-api-status {
            font-size: 20px;
        }
        
        /* Generation Progress */
        .fg-progress {
            display: none;
            text-align: center;
            padding: 40px 20px;
        }
        .fg-progress.active { display: block; }
        .fg-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid #333;
            border-top-color: #10B981;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .fg-progress-text {
            font-size: 16px;
            color: #888;
        }
        .fg-progress-sub {
            font-size: 13px;
            color: #555;
            margin-top: 8px;
        }
        
        /* Output Tabs */
        .fg-output { display: none; }
        .fg-output.active { display: block; }
        .fg-output-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
            border-bottom: 1px solid #222;
            padding-bottom: 12px;
        }
        .fg-output-tab {
            background: #0a0a0a;
            border: 1px solid #333;
            color: #888;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }
        .fg-output-tab:hover { color: #fff; border-color: #444; }
        .fg-output-tab.active { background: #10B981; color: #fff; border-color: #10B981; }
        .fg-output-tab.empty { 
            background: transparent; 
            border-style: dashed; 
            color: #555; 
        }
        .fg-output-tab.empty:hover { 
            border-color: #10B981; 
            color: #10B981; 
        }
        .fg-output-tab .tab-status {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            margin-left: 6px;
        }
        .fg-output-tab .tab-status.ready { background: #22c55e; }
        .fg-output-tab .tab-status.empty { background: #555; }
        
        /* Preview Container */
        .fg-preview-container {
            background: #0a0a0a;
            border: 1px solid #333;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 16px;
            height: 350px;
        }
        .fg-preview-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 14px;
            background: #111;
            border-bottom: 1px solid #222;
        }
        .fg-preview-title {
            font-size: 12px;
            font-weight: 600;
            color: #888;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .fg-preview-title .dot {
            width: 8px;
            height: 8px;
            background: #22c55e;
            border-radius: 50%;
        }
        .fg-preview-actions {
            display: flex;
            gap: 6px;
        }
        .fg-preview-action {
            background: #222;
            border: none;
            color: #888;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .fg-preview-action:hover { background: #333; color: #fff; }
        .fg-preview-iframe {
            width: 100%;
            height: calc(100% - 42px);
            border: none;
            background: #0a0a0a;
        }
        .fg-preview-empty {
            height: calc(100% - 42px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #555;
            gap: 12px;
        }
        .fg-preview-empty-icon {
            font-size: 32px;
            opacity: 0.5;
        }
        .fg-preview-empty-text {
            font-size: 13px;
        }
        .fg-preview-empty-btn {
            background: linear-gradient(135deg, #10B981, #059669);
            border: none;
            color: #fff;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
        }
        .fg-preview-empty-btn:hover { opacity: 0.9; }
        
        .fg-output-actions {
            display: flex;
            gap: 10px;
        }
        .fg-load-btn {
            flex: 1;
            background: #10B981;
            border: none;
            color: #fff;
            padding: 14px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }
        .fg-load-btn:hover { opacity: 0.9; }
        .fg-copy-btn {
            background: #333;
            border: none;
            color: #fff;
            padding: 14px 20px;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
        }
        .fg-copy-btn:hover { background: #444; }
    </style>
</head>
<body>
    <!-- ═══════════════════════════════════════════════════════════════════════
         TOP BAR
         ═══════════════════════════════════════════════════════════════════════ -->
    <div class="top-bar">
        <div class="top-left">
            <div class="logo">Funnel <span>Builder</span></div>
            <div class="device-btns">
                <button class="device-btn active" onclick="setDevice('Desktop')" title="Desktop">🖥️</button>
                <button class="device-btn" onclick="setDevice('Tablet')" title="Tablet">📱</button>
                <button class="device-btn" onclick="setDevice('Mobile')" title="Mobile">📲</button>
            </div>
        </div>
        <div class="top-center">
            <button class="tool-btn" onclick="editor.runCommand('core:undo')" title="Undo">↩ Undo</button>
            <button class="tool-btn" onclick="editor.runCommand('core:redo')" title="Redo">↪ Redo</button>
            <button class="tool-btn" onclick="refreshStyles()" title="Refresh Styles">🔄 Refresh</button>
            <button class="tool-btn" onclick="editor.runCommand('core:canvas-clear')" title="Clear Canvas">🗑️ Clear</button>
            <button class="tool-btn" onclick="editor.runCommand('core:fullscreen')" title="Fullscreen">⛶ Fullscreen</button>
        </div>
        <div class="top-right">
            <button class="btn" style="background: linear-gradient(135deg, #10B981, #059669);" onclick="openFunnelGenerator()">🚀 Generate Funnel</button>
            <button class="btn btn-templates" onclick="openTemplatesModal()">📄 Templates</button>
            <button class="btn btn-ai" onclick="toggleAIPanel()">🤖 AI Assistant</button>
            <button class="btn btn-dark" onclick="openLoadModal()">📥 Load</button>
            <button class="btn btn-dark" onclick="previewPage()">👁 Preview</button>
            <button class="btn btn-red" onclick="openExportModal()">📤 Export</button>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MAIN EDITOR
         ═══════════════════════════════════════════════════════════════════════ -->
    <div class="editor-container">
        <!-- Left Panel - Blocks -->
        <div class="panel-left">
            <div class="panel-header">+ Add Elements</div>
            <div class="blocks-container" id="blocks"></div>
        </div>

        <!-- Canvas -->
        <div id="gjs"></div>

        <!-- Right Panel - Styles/Layers/Settings -->
        <div class="panel-right">
            <div class="panel-tabs">
                <div class="panel-tab active" onclick="showPanel('styles')">Styles</div>
                <div class="panel-tab" onclick="showPanel('layers')">Layers</div>
                <div class="panel-tab" onclick="showPanel('settings')">Settings</div>
            </div>
            <div class="panel-content active" id="styles-panel">
                <!-- Color Swatches -->
                <div class="color-swatches" id="colorSwatches">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                        <div class="color-swatches-title" style="margin-bottom: 0;">Quick Colors</div>
                        <div style="display: flex; gap: 4px;">
                            <button id="colorModeText" class="color-mode-btn active" onclick="setColorMode('text')">Text</button>
                            <button id="colorModeBg" class="color-mode-btn" onclick="setColorMode('bg')">BG</button>
                        </div>
                    </div>
                    <div class="color-swatches-grid">
                        <div class="color-swatch" style="background: #ffffff;" onclick="applySelectedColor('#ffffff')" title="White"></div>
                        <div class="color-swatch" style="background: #a1a1aa;" onclick="applySelectedColor('#a1a1aa')" title="Gray"></div>
                        <div class="color-swatch" style="background: #71717a;" onclick="applySelectedColor('#71717a')" title="Dark Gray"></div>
                        <div class="color-swatch" style="background: #000000;" onclick="applySelectedColor('#000000')" title="Black"></div>
                        <div class="color-swatch" style="background: #dc2626;" onclick="applySelectedColor('#dc2626')" title="Red"></div>
                        <div class="color-swatch" style="background: #f97316;" onclick="applySelectedColor('#f97316')" title="Orange"></div>
                        <div class="color-swatch" style="background: #f59e0b;" onclick="applySelectedColor('#f59e0b')" title="Amber"></div>
                        <div class="color-swatch" style="background: #eab308;" onclick="applySelectedColor('#eab308')" title="Yellow"></div>
                        <div class="color-swatch" style="background: #22c55e;" onclick="applySelectedColor('#22c55e')" title="Green"></div>
                        <div class="color-swatch" style="background: #10b981;" onclick="applySelectedColor('#10b981')" title="Emerald"></div>
                        <div class="color-swatch" style="background: #06b6d4;" onclick="applySelectedColor('#06b6d4')" title="Cyan"></div>
                        <div class="color-swatch" style="background: #3b82f6;" onclick="applySelectedColor('#3b82f6')" title="Blue"></div>
                        <div class="color-swatch" style="background: #8b5cf6;" onclick="applySelectedColor('#8b5cf6')" title="Violet"></div>
                        <div class="color-swatch" style="background: #a855f7;" onclick="applySelectedColor('#a855f7')" title="Purple"></div>
                        <div class="color-swatch" style="background: #ec4899;" onclick="applySelectedColor('#ec4899')" title="Pink"></div>
                        <div class="color-swatch" style="background: #0a0a0a;" onclick="applySelectedColor('#0a0a0a')" title="Dark BG"></div>
                    </div>
                </div>
                <!-- GrapesJS Style Manager will append here -->
            </div>
            <div class="panel-content" id="layers-panel"></div>
            <div class="panel-content" id="settings-panel"></div>
        </div>
    </div>

    <!-- Status Bar -->
    <div class="status-bar" id="statusBar"></div>

    <!-- Load Modal -->
    <div class="modal" id="loadModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>📥 Load HTML Code</h3>
                <button class="modal-close" onclick="closeLoadModal()">×</button>
            </div>
            <div class="modal-body">
                <div class="modal-hint">
                    Paste your HTML code below. You can load any landing page code and edit it visually.
                </div>
                <textarea id="loadCode" placeholder="Paste HTML code here..."></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-dark" onclick="closeLoadModal()">Cancel</button>
                <button class="btn btn-red" onclick="loadCode()">Load into Editor</button>
            </div>
        </div>
    </div>

    <!-- Export Modal -->
    <div class="modal" id="exportModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>📤 Export HTML</h3>
                <button class="modal-close" onclick="closeExportModal()">×</button>
            </div>
            <div class="modal-body">
                <div class="modal-hint">
                    Copy this code and paste into GHL → Custom Code element.
                </div>
                <textarea id="exportCode" readonly></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-dark" onclick="downloadFile()">⬇ Download</button>
                <button class="btn btn-red" onclick="copyCode()">📋 Copy</button>
            </div>
        </div>
    </div>

    <!-- AI Assistant Panel -->
    <div class="ai-panel" id="aiPanel">
        <div class="ai-panel-header">
            <h3>🤖 AI Copywriting Assistant</h3>
            <button class="ai-panel-close" onclick="toggleAIPanel()">×</button>
        </div>
        <div class="prompt-gen-body">
            <p class="prompt-intro">Generate prompts loaded with direct response frameworks, your market research, and funnel context. Copy → Paste into Claude!</p>
            
            <div class="prompt-section">
                <div class="prompt-section-title">🎯 Generate Copy</div>
                <div class="prompt-grid">
                    <button class="prompt-btn" onclick="generatePrompt('headlines')">📝 Headlines</button>
                    <button class="prompt-btn" onclick="generatePrompt('vsl')">🎬 VSL Script</button>
                    <button class="prompt-btn" onclick="generatePrompt('hero')">🏠 Hero Section</button>
                    <button class="prompt-btn" onclick="generatePrompt('cta')">🎯 CTA Copy</button>
                    <button class="prompt-btn" onclick="generatePrompt('proof')">⭐ Social Proof</button>
                    <button class="prompt-btn" onclick="generatePrompt('bullets')">💥 Bullet Points</button>
                    <button class="prompt-btn" onclick="generatePrompt('email')">📧 Email</button>
                    <button class="prompt-btn" onclick="generatePrompt('ad')">📱 Ad Copy</button>
                </div>
            </div>
            
            <div class="prompt-section">
                <div class="prompt-section-title">🔍 Analyze Funnel</div>
                <div class="prompt-grid">
                    <button class="prompt-btn" onclick="generatePrompt('analyze')">🔍 Full Analysis</button>
                    <button class="prompt-btn" onclick="generatePrompt('improve')">💡 Improvements</button>
                </div>
            </div>
            
            <div class="prompt-section">
                <div class="prompt-section-title">⚙️ Custom Prompt</div>
                <textarea class="custom-prompt-input" id="customPromptInput" placeholder="Describe what you need... (e.g., 'Write an urgency-focused closing section')"></textarea>
                <button class="prompt-btn-full" onclick="generatePrompt('custom')">📋 Generate Custom Prompt</button>
            </div>
        </div>
        <div class="prompt-output-area" id="promptOutputArea" style="display:none;">
            <div class="prompt-output-header">
                <span>📋 Your Prompt (Ready to Copy)</span>
                <button class="prompt-back-btn" onclick="hidePromptOutput()">← Back</button>
            </div>
            <textarea class="prompt-output" id="promptOutput" readonly></textarea>
            <button class="copy-prompt-btn" onclick="copyPromptToClipboard()">📋 Copy to Clipboard</button>
        </div>
    </div>

    <!-- Templates Modal -->
    <div class="templates-modal" id="templatesModal">
        <div class="templates-box">
            <div class="templates-header">
                <h3>📄 Page Templates</h3>
                <button class="modal-close" onclick="closeTemplatesModal()">×</button>
            </div>
            <div class="templates-body">
                <div class="template-card" onclick="loadTemplate('vsl')">
                    <div class="template-card-icon">🎬</div>
                    <h4>VSL Landing Page</h4>
                    <p>Video sales letter page with headline, video embed, CTA button, social proof stats, and testimonials. Ready for your funding offer.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Funnel Generator Modal -->
    <div class="funnel-gen-modal" id="funnelGenModal">
        <div class="funnel-gen-box">
            <div class="funnel-gen-header">
                <h3>🚀 AI Funnel Generator</h3>
                <button class="modal-close" onclick="closeFunnelGenerator()" style="background:rgba(255,255,255,0.2);border:none;color:#fff;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:20px;">×</button>
            </div>
            <div class="funnel-gen-body" id="fgForm">
                <!-- API Key -->
                <div class="fg-section">
                    <label class="fg-label">API Key</label>
                    <div class="fg-api-row">
                        <input type="password" class="fg-input fg-api-input" id="fgApiKey" placeholder="sk-ant-..." onchange="saveFgApiKey()">
                        <span class="fg-api-status" id="fgApiStatus">⚪</span>
                    </div>
                </div>
                
                <!-- Accent Color -->
                <div class="fg-section">
                    <label class="fg-label">Accent Color</label>
                    <div class="fg-color-grid">
                        <div class="fg-color-option selected" style="background: #10B981;" data-color="emerald" onclick="selectFgColor(this)"></div>
                        <div class="fg-color-option" style="background: #3B82F6;" data-color="blue" onclick="selectFgColor(this)"></div>
                        <div class="fg-color-option" style="background: #8B5CF6;" data-color="violet" onclick="selectFgColor(this)"></div>
                        <div class="fg-color-option" style="background: #F59E0B;" data-color="amber" onclick="selectFgColor(this)"></div>
                        <div class="fg-color-option" style="background: #F97316;" data-color="coral" onclick="selectFgColor(this)"></div>
                        <div class="fg-color-option" style="background: #06B6D4;" data-color="cyan" onclick="selectFgColor(this)"></div>
                    </div>
                </div>
                
                <!-- Unique Mechanism -->
                <div class="fg-section">
                    <label class="fg-label">Unique Mechanism Name</label>
                    <input type="text" class="fg-input" id="fgMechanism" placeholder='e.g., "Secondary Bureau Attack Method"'>
                </div>
                
                <!-- Page Type -->
                <div class="fg-section">
                    <label class="fg-label">Generate</label>
                    <div class="fg-page-btns">
                        <div class="fg-page-btn selected" data-page="landing" onclick="selectFgPage(this)">
                            <div class="fg-page-btn-icon">🎬</div>
                            <div class="fg-page-btn-label">Landing Page</div>
                        </div>
                        <div class="fg-page-btn" data-page="thankyou" onclick="selectFgPage(this)">
                            <div class="fg-page-btn-icon">✅</div>
                            <div class="fg-page-btn-label">Thank You Page</div>
                        </div>
                        <div class="fg-page-btn" data-page="both" onclick="selectFgPage(this)">
                            <div class="fg-page-btn-icon">📦</div>
                            <div class="fg-page-btn-label">Both Pages</div>
                        </div>
                    </div>
                </div>
                
                <button class="fg-generate-btn" id="fgGenerateBtn" onclick="generateFunnel()">🚀 Generate Funnel</button>
            </div>
            
            <!-- Progress -->
            <div class="fg-progress" id="fgProgress">
                <div class="fg-spinner"></div>
                <div class="fg-progress-text">Generating your funnel...</div>
                <div class="fg-progress-sub">This may take 30-60 seconds</div>
            </div>
            
            <!-- Output -->
            <div class="fg-output" id="fgOutput">
                <div class="fg-output-tabs" id="fgOutputTabs">
                    <!-- Tabs inserted dynamically -->
                </div>
                
                <!-- Preview Container -->
                <div class="fg-preview-container">
                    <div class="fg-preview-header">
                        <div class="fg-preview-title">
                            <span class="dot"></span>
                            <span id="fgPreviewLabel">Preview</span>
                        </div>
                        <div class="fg-preview-actions">
                            <button class="fg-preview-action" onclick="openPreviewNewTab()">↗ Open in New Tab</button>
                        </div>
                    </div>
                    <iframe id="fgPreviewIframe" class="fg-preview-iframe"></iframe>
                    <div id="fgPreviewEmpty" class="fg-preview-empty" style="display: none;">
                        <div class="fg-preview-empty-icon">📄</div>
                        <div class="fg-preview-empty-text">No page generated yet</div>
                        <button class="fg-preview-empty-btn" onclick="generateMissingPage()">+ Generate This Page</button>
                    </div>
                </div>
                
                <div class="fg-output-actions">
                    <button class="fg-load-btn" onclick="loadGeneratedToEditor()">📥 Load into Editor</button>
                    <button class="fg-copy-btn" onclick="copyGeneratedCode()">📋 Copy Code</button>
                    <button class="fg-copy-btn" onclick="resetFunnelGenerator()">🔄 Start Over</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/grapesjs@0.21.10"></script>
    <script>
        // Store loaded CSS globally for export
        let loadedCSS = '';
        
        // Store custom code blocks (id -> code)
        const customCodeStorage = {};
        
        // ═══════════════════════════════════════════════════════════════════════
        // INITIALIZE EDITOR
        // ═══════════════════════════════════════════════════════════════════════
        const editor = grapesjs.init({
            container: '#gjs',
            height: '100%',
            width: 'auto',
            fromElement: false,
            storageManager: false,

            // Canvas
            canvas: {
                styles: [
                    'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap'
                ],
                frameStyle: `
                    body { background: #0a0a0a; }
                    html { background: #0a0a0a; }
                `
            },

            // Protect base CSS
            protectedCss: `
                html, body { background: #0a0a0a !important; }
            `,

            // Default CSS
            style: `
                html { background: #0a0a0a !important; }
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body { 
                    font-family: 'Inter', sans-serif; 
                    background: #0a0a0a !important; 
                    color: #fff; 
                    line-height: 1.6;
                    min-height: 100vh;
                }
            `,

            // Devices
            deviceManager: {
                devices: [
                    { name: 'Desktop', width: '' },
                    { name: 'Tablet', width: '768px', widthMedia: '992px' },
                    { name: 'Mobile', width: '375px', widthMedia: '480px' }
                ]
            },

            // Panels - we're using custom panels
            panels: { defaults: [] },

            // Block Manager
            blockManager: {
                appendTo: '#blocks'
            },

            // Style Manager
            styleManager: {
                appendTo: '#styles-panel',
                sectors: [
                    {
                        name: 'Layout',
                        open: true,
                        properties: [
                            { property: 'display', type: 'select', options: [
                                { value: 'block', name: 'Block' },
                                { value: 'flex', name: 'Flex' },
                                { value: 'grid', name: 'Grid' },
                                { value: 'inline-block', name: 'Inline Block' },
                                { value: 'none', name: 'None' }
                            ]},
                            { property: 'flex-direction', type: 'select', options: [
                                { value: 'row', name: 'Row' },
                                { value: 'column', name: 'Column' }
                            ]},
                            { property: 'justify-content', type: 'select', options: [
                                { value: 'flex-start', name: 'Start' },
                                { value: 'center', name: 'Center' },
                                { value: 'flex-end', name: 'End' },
                                { value: 'space-between', name: 'Space Between' },
                                { value: 'space-around', name: 'Space Around' }
                            ]},
                            { property: 'align-items', type: 'select', options: [
                                { value: 'flex-start', name: 'Start' },
                                { value: 'center', name: 'Center' },
                                { value: 'flex-end', name: 'End' },
                                { value: 'stretch', name: 'Stretch' }
                            ]},
                            { property: 'gap' }
                        ]
                    },
                    {
                        name: 'Size',
                        open: false,
                        properties: [
                            { property: 'width' },
                            { property: 'height' },
                            { property: 'max-width' },
                            { property: 'min-height' },
                            { property: 'padding' },
                            { property: 'margin' }
                        ]
                    },
                    {
                        name: 'Typography',
                        open: false,
                        properties: [
                            { property: 'font-family', type: 'select', options: [
                                { value: "'Inter', sans-serif", name: 'Inter' },
                                { value: 'Arial, sans-serif', name: 'Arial' },
                                { value: 'Georgia, serif', name: 'Georgia' }
                            ]},
                            { property: 'font-size' },
                            { property: 'font-weight', type: 'select', options: [
                                { value: '400', name: 'Normal' },
                                { value: '500', name: 'Medium' },
                                { value: '600', name: 'Semi Bold' },
                                { value: '700', name: 'Bold' },
                                { value: '800', name: 'Extra Bold' },
                                { value: '900', name: 'Black' }
                            ]},
                            { property: 'color', type: 'color' },
                            { property: 'text-align', type: 'radio', options: [
                                { value: 'left', name: 'Left' },
                                { value: 'center', name: 'Center' },
                                { value: 'right', name: 'Right' }
                            ]},
                            { property: 'line-height' },
                            { property: 'letter-spacing' },
                            { property: 'text-decoration', type: 'select', options: [
                                { value: 'none', name: 'None' },
                                { value: 'underline', name: 'Underline' },
                                { value: 'line-through', name: 'Strikethrough' }
                            ]},
                            { property: 'text-transform', type: 'select', options: [
                                { value: 'none', name: 'None' },
                                { value: 'uppercase', name: 'UPPERCASE' },
                                { value: 'lowercase', name: 'lowercase' },
                                { value: 'capitalize', name: 'Capitalize' }
                            ]}
                        ]
                    },
                    {
                        name: 'Background',
                        open: false,
                        properties: [
                            { property: 'background-color', type: 'color' },
                            { property: 'background-image' },
                            { property: 'background-size', type: 'select', options: [
                                { value: 'auto', name: 'Auto' },
                                { value: 'cover', name: 'Cover' },
                                { value: 'contain', name: 'Contain' }
                            ]}
                        ]
                    },
                    {
                        name: 'Border',
                        open: false,
                        properties: [
                            { property: 'border-radius' },
                            { property: 'border-width' },
                            { property: 'border-style', type: 'select', options: [
                                { value: 'none', name: 'None' },
                                { value: 'solid', name: 'Solid' },
                                { value: 'dashed', name: 'Dashed' },
                                { value: 'dotted', name: 'Dotted' }
                            ]},
                            { property: 'border-color', type: 'color' }
                        ]
                    },
                    {
                        name: 'Effects',
                        open: false,
                        properties: [
                            { property: 'opacity' },
                            { property: 'box-shadow' }
                        ]
                    }
                ]
            },

            // Layer Manager
            layerManager: {
                appendTo: '#layers-panel'
            },

            // Trait Manager
            traitManager: {
                appendTo: '#settings-panel'
            },

            // Selector Manager
            selectorManager: {
                appendTo: '#styles-panel',
                componentFirst: true
            }
        });

        // ═══════════════════════════════════════════════════════════════════════
        // CUSTOM COMPONENT TYPES
        // ═══════════════════════════════════════════════════════════════════════
        
        // Custom Code Component - for embedding videos, scripts, etc.
        editor.DomComponents.addType('custom-code', {
            model: {
                defaults: {
                    tagName: 'div',
                    droppable: false,
                    attributes: { 'data-type': 'custom-code' },
                    style: {
                        'max-width': '800px',
                        'margin': '0 auto',
                        'min-height': '100px',
                        'background': '#111',
                        'border': '1px solid #222',
                        'border-radius': '12px',
                        'overflow': 'hidden'
                    },
                    'custom-code': '',
                    traits: [
                        {
                            type: 'text',
                            label: 'Name',
                            name: 'id',
                            placeholder: 'e.g. vsl-video'
                        },
                        {
                            type: 'button',
                            label: 'Embed Code',
                            text: 'Edit Code',
                            full: true,
                            command: 'open-code-editor'
                        }
                    ]
                },
                init: function() {
                    this.on('change:custom-code', this.handleCodeChange);
                    if (!this.get('custom-code')) {
                        this.components('<div style="padding: 40px; text-align: center;"><div style="font-size: 32px; margin-bottom: 12px;">📝</div><p style="color: #71717a; font-size: 14px; margin: 0;">Custom Code Block</p><p style="color: #52525b; font-size: 12px; margin-top: 8px;">Select and click "Edit Code" in Settings</p></div>');
                    }
                },
                handleCodeChange: function() {
                    const code = this.get('custom-code');
                    if (code) {
                        this.components(code);
                    }
                }
            }
        });

        // CTA Button Component - with link/action support
        editor.DomComponents.addType('cta-button', {
            model: {
                defaults: {
                    tagName: 'a',
                    attributes: { href: '#', class: 'cta-btn' },
                    style: {
                        'display': 'inline-flex',
                        'align-items': 'center',
                        'gap': '8px',
                        'background': 'linear-gradient(135deg, #dc2626, #b91c1c)',
                        'color': '#fff',
                        'font-size': '18px',
                        'font-weight': '700',
                        'padding': '20px 44px',
                        'border-radius': '12px',
                        'border': 'none',
                        'cursor': 'pointer',
                        'box-shadow': '0 0 40px rgba(220,38,38,0.4)',
                        'text-decoration': 'none'
                    },
                    content: 'Get Approved →',
                    traits: [
                        {
                            type: 'text',
                            label: 'Button Text',
                            name: 'content',
                            changeProp: true
                        },
                        {
                            type: 'select',
                            label: 'Action Type',
                            name: 'action-type',
                            options: [
                                { value: 'link', name: 'Go to URL' },
                                { value: 'survey', name: 'Open Survey Modal' },
                                { value: 'scroll', name: 'Scroll to Section' }
                            ]
                        },
                        {
                            type: 'text',
                            label: 'URL / Survey ID / Section ID',
                            name: 'href',
                            placeholder: 'https://... or #section-id'
                        },
                        {
                            type: 'select',
                            label: 'Open In',
                            name: 'target',
                            options: [
                                { value: '_self', name: 'Same Window' },
                                { value: '_blank', name: 'New Tab' }
                            ]
                        }
                    ]
                }
            }
        });

        // Auto-switch to Settings tab and show custom controls
        editor.on('component:selected', (component) => {
            if (!component) return;
            
            // Show settings panel
            showPanel('settings');
            
            // Remove any existing custom controls
            const existingControls = document.getElementById('custom-element-controls');
            if (existingControls) existingControls.remove();
            
            // Get element info
            const el = component.getEl();
            const tagName = (component.get('tagName') || '').toLowerCase();
            const attrs = component.getAttributes();
            
            // Find the custom code block - check self and walk up parents
            let customCodeComponent = null;
            let checkComponent = component;
            
            while (checkComponent) {
                const checkEl = checkComponent.getEl();
                const checkAttrs = checkComponent.getAttributes();
                
                if (checkAttrs['data-type'] === 'custom-code' || 
                    (checkEl && checkEl.classList && checkEl.classList.contains('custom-code-block')) ||
                    (checkEl && checkEl.getAttribute && checkEl.getAttribute('data-type') === 'custom-code')) {
                    customCodeComponent = checkComponent;
                    break;
                }
                checkComponent = checkComponent.parent();
            }
            
            const isCustomCode = customCodeComponent !== null;
            const isLink = tagName === 'a';
            const isButton = tagName === 'button' || (el && el.className && typeof el.className === 'string' && el.className.includes('btn'));
            
            // Create custom controls container
            const controlsDiv = document.createElement('div');
            controlsDiv.id = 'custom-element-controls';
            controlsDiv.style.cssText = 'padding: 16px; border-bottom: 1px solid #222;';
            
            if (isCustomCode) {
                // Use the found custom code component
                const targetComponent = customCodeComponent;
                
                // Custom Code controls
                controlsDiv.innerHTML = 
                    '<div style="margin-bottom: 12px;">' +
                    '<div style="font-size: 11px; font-weight: 600; color: #dc2626; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">📝 Custom Code</div>' +
                    '<button id="editCodeBtn" style="width: 100%; padding: 12px; background: linear-gradient(135deg, #dc2626, #b91c1c); color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer;">Edit Embed Code</button>' +
                    '</div>';
                
                // Insert at top of settings panel
                const settingsPanel = document.getElementById('settings-panel');
                settingsPanel.insertBefore(controlsDiv, settingsPanel.firstChild);
                
                // Add click handler
                document.getElementById('editCodeBtn').onclick = function() {
                    openCodeEditorModal(targetComponent);
                };
            } else if (isLink || isButton) {
                // Get or create button ID (using underscores for valid JS function names)
                let btnId = component.getAttributes()['data-btn-id'];
                if (!btnId) {
                    btnId = 'btn_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
                    component.addAttributes({ 'data-btn-id': btnId });
                }
                
                // Get current settings
                const currentHref = component.getAttributes().href || '#';
                const currentAction = component.getAttributes()['data-action'] || 'link';
                const hasEmbed = buttonEmbedStorage[btnId] ? true : false;
                
                controlsDiv.innerHTML = 
                    '<div style="margin-bottom: 12px;">' +
                    '<div style="font-size: 11px; font-weight: 600; color: #dc2626; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">🔗 Button Settings</div>' +
                    '<label style="display: block; font-size: 11px; color: #888; margin-bottom: 6px;">Click Action</label>' +
                    '<select id="btnActionSelect" style="width: 100%; padding: 10px; background: #111; border: 1px solid #333; border-radius: 6px; color: #fff; font-size: 12px; margin-bottom: 12px;">' +
                    '<option value="link"' + (currentAction === 'link' ? ' selected' : '') + '>Go to URL</option>' +
                    '<option value="modal"' + (currentAction === 'modal' ? ' selected' : '') + '>Open Survey Modal</option>' +
                    '</select>' +
                    '<div id="linkOptions" style="' + (currentAction === 'link' ? '' : 'display:none;') + '">' +
                    '<label style="display: block; font-size: 11px; color: #888; margin-bottom: 6px;">URL</label>' +
                    '<input type="text" id="linkUrlInput" value="' + (currentAction === 'link' ? currentHref : '') + '" placeholder="https://..." style="width: 100%; padding: 10px; background: #111; border: 1px solid #333; border-radius: 6px; color: #fff; font-size: 12px;">' +
                    '</div>' +
                    '<div id="modalOptions" style="' + (currentAction === 'modal' ? '' : 'display:none;') + '">' +
                    '<button id="editSurveyBtn" style="width: 100%; padding: 12px; background: linear-gradient(135deg, #dc2626, #b91c1c); color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; margin-bottom: 8px;">Edit Survey Embed Code</button>' +
                    '<div id="surveyStatus" style="font-size: 11px; color: ' + (hasEmbed ? '#22c55e' : '#71717a') + '; text-align: center;">' + (hasEmbed ? '✅ Survey code saved' : 'No survey code added yet') + '</div>' +
                    '</div>' +
                    '</div>';
                
                // Insert at top of settings panel
                const settingsPanel = document.getElementById('settings-panel');
                settingsPanel.insertBefore(controlsDiv, settingsPanel.firstChild);
                
                // Action type change handler
                document.getElementById('btnActionSelect').onchange = function() {
                    const action = this.value;
                    component.addAttributes({ 'data-action': action });
                    
                    if (action === 'link') {
                        document.getElementById('linkOptions').style.display = '';
                        document.getElementById('modalOptions').style.display = 'none';
                        component.addAttributes({ href: document.getElementById('linkUrlInput').value || '#' });
                    } else {
                        document.getElementById('linkOptions').style.display = 'none';
                        document.getElementById('modalOptions').style.display = '';
                        component.addAttributes({ href: '#', onclick: 'openSurveyModal_' + btnId + '(); return false;' });
                    }
                };
                
                // URL change handler
                document.getElementById('linkUrlInput').onchange = function() {
                    component.addAttributes({ href: this.value });
                };
                
                // Survey embed button handler
                document.getElementById('editSurveyBtn').onclick = function() {
                    openSurveyEmbedModal(component, btnId);
                };
            }
        });
        
        // Store button survey embeds
        const buttonEmbedStorage = {};
        
        // Survey embed modal function
        function openSurveyEmbedModal(component, btnId) {
            const currentCode = buttonEmbedStorage[btnId] || '';
            
            const modal = document.createElement('div');
            modal.className = 'code-editor-modal active';
            modal.id = 'surveyEditorModal';
            modal.innerHTML = 
                '<div class="code-editor-box">' +
                '<div class="code-editor-header">' +
                '<h3>📋 Edit Survey Embed Code</h3>' +
                '<button class="code-editor-close" id="closeSurveyEditor">×</button>' +
                '</div>' +
                '<div class="code-editor-body">' +
                '<div class="code-editor-hint">Paste your survey embed code below (GHL survey, Typeform, etc.). The survey will open in a modal popup when the button is clicked.</div>' +
                '<textarea id="surveyCodeInput" placeholder="<iframe src=&quot;https://api.leadconnectorhq.com/widget/survey/...&quot;></iframe>"></textarea>' +
                '</div>' +
                '<div class="code-editor-footer">' +
                '<button class="btn btn-dark" id="cancelSurveyEditor">Cancel</button>' +
                '<button class="btn btn-red" id="saveSurveyEditor">Save Survey</button>' +
                '</div>' +
                '</div>';
            
            document.body.appendChild(modal);
            
            const textarea = document.getElementById('surveyCodeInput');
            textarea.value = currentCode;
            textarea.focus();
            
            // Close handlers
            document.getElementById('closeSurveyEditor').onclick = function() { modal.remove(); };
            document.getElementById('cancelSurveyEditor').onclick = function() { modal.remove(); };
            
            // Save handler
            document.getElementById('saveSurveyEditor').onclick = function() {
                const code = textarea.value;
                buttonEmbedStorage[btnId] = code;
                
                // Update button attributes
                component.addAttributes({ 
                    'data-action': 'modal',
                    'data-btn-id': btnId,
                    href: '#',
                    onclick: 'openSurveyModal_' + btnId + '(); return false;'
                });
                
                // Update status
                const statusEl = document.getElementById('surveyStatus');
                if (statusEl) {
                    statusEl.textContent = code ? '✅ Survey code saved' : 'No survey code added yet';
                    statusEl.style.color = code ? '#22c55e' : '#71717a';
                }
                
                modal.remove();
                showStatus('✓ Survey saved! Click Preview to test.');
            };
            
            modal.onclick = function(e) { if (e.target === modal) modal.remove(); };
        }
        
        // Code editor modal function
        function openCodeEditorModal(component) {
            // Get or create unique ID for this custom code block
            let blockId = component.getAttributes()['data-code-id'];
            if (!blockId) {
                blockId = 'cc-' + Date.now() + '-' + Math.random().toString(36).substr(2, 9);
                component.addAttributes({ 'data-code-id': blockId });
            }
            
            // Get current code - check storage first, then component property
            let currentCode = customCodeStorage[blockId] || component.get('custom-code') || '';
            
            // If no stored code, check innerHTML but filter out placeholder
            if (!currentCode) {
                const innerHTML = component.getInnerHTML() || '';
                // Don't use innerHTML if it's the placeholder
                if (!innerHTML.includes('Custom Code Block') && !innerHTML.includes('Edit Embed Code')) {
                    currentCode = innerHTML;
                }
            }
            
            const modal = document.createElement('div');
            modal.className = 'code-editor-modal active';
            modal.id = 'codeEditorModal';
            modal.innerHTML = 
                '<div class="code-editor-box">' +
                '<div class="code-editor-header">' +
                '<h3>📝 Edit Embed Code</h3>' +
                '<button class="code-editor-close" id="closeCodeEditor">×</button>' +
                '</div>' +
                '<div class="code-editor-body">' +
                '<div class="code-editor-hint">Paste your embed code below (Wistia, YouTube, Vimeo, survey forms, scripts, etc.)</div>' +
                '<textarea id="embedCodeInput" placeholder="Paste your embed code here..."></textarea>' +
                '</div>' +
                '<div class="code-editor-footer">' +
                '<button class="btn btn-dark" id="cancelCodeEditor">Cancel</button>' +
                '<button class="btn btn-red" id="saveCodeEditor">Save Code</button>' +
                '</div>' +
                '</div>';
            
            document.body.appendChild(modal);
            
            // Set textarea value after adding to DOM (avoids HTML encoding issues)
            const textarea = document.getElementById('embedCodeInput');
            textarea.value = currentCode;
            textarea.focus();
            
            // Close handlers
            document.getElementById('closeCodeEditor').onclick = function() {
                modal.remove();
            };
            document.getElementById('cancelCodeEditor').onclick = function() {
                modal.remove();
            };
            
            // Save handler
            document.getElementById('saveCodeEditor').onclick = function() {
                const code = textarea.value;
                
                // Store in global storage for export
                customCodeStorage[blockId] = code;
                
                // Also store on component
                component.set('custom-code', code);
                
                // Update visual representation (without scripts for editor display)
                if (code.trim()) {
                    // For editor display, show a preview or placeholder for script content
                    const hasScript = code.includes('<script');
                    if (hasScript) {
                        // Show a visual indicator that code is saved (with data attribute for easy removal in preview)
                        component.components('<div data-editor-only="true" style="padding: 40px; text-align: center; background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); border-radius: 8px; margin: 10px;"><div style="font-size: 32px; margin-bottom: 12px;">✅</div><p style="color: #22c55e; font-size: 14px; margin: 0;">Embed Code Saved</p><p style="color: #71717a; font-size: 12px; margin-top: 8px;">Script will render in Preview/Export</p></div>');
                    } else {
                        component.components(code);
                    }
                } else {
                    component.components('<div data-editor-only="true" style="padding: 40px; text-align: center;"><div style="font-size: 32px; margin-bottom: 12px;">📝</div><p style="color: #71717a; font-size: 14px;">Custom Code Block</p><p style="color: #52525b; font-size: 12px; margin-top: 8px;">Click "Edit Embed Code" to add content</p></div>');
                }
                
                modal.remove();
                showStatus('✓ Code saved!');
                setTimeout(reinjectCSS, 100);
            };
            
            // Close on escape or background click
            modal.onclick = function(e) {
                if (e.target === modal) modal.remove();
            };
        }

        // Add default traits to link elements
        editor.DomComponents.addType('link', {
            model: {
                defaults: {
                    traits: [
                        {
                            type: 'text',
                            label: 'URL',
                            name: 'href',
                            placeholder: 'https://... or #section-id'
                        },
                        {
                            type: 'select',
                            label: 'Open In',
                            name: 'target',
                            options: [
                                { value: '_self', name: 'Same Window' },
                                { value: '_blank', name: 'New Tab' }
                            ]
                        },
                        {
                            type: 'text',
                            label: 'Title',
                            name: 'title',
                            placeholder: 'Link title (hover text)'
                        }
                    ]
                }
            }
        });

        // Add traits to buttons (for onclick actions)
        editor.DomComponents.addType('button', {
            model: {
                defaults: {
                    traits: [
                        {
                            type: 'text',
                            label: 'Button Text',
                            name: 'text'
                        },
                        {
                            type: 'text',
                            label: 'On Click',
                            name: 'onclick',
                            placeholder: "window.location='https://...'"
                        }
                    ]
                }
            }
        });

        // ═══════════════════════════════════════════════════════════════════════
        // FUNNEL BLOCKS
        // ═══════════════════════════════════════════════════════════════════════
        const bm = editor.BlockManager;

        // ─────────────────────────────────────────────────────────────────────────
        // BASIC ELEMENTS
        // ─────────────────────────────────────────────────────────────────────────
        bm.add('section', {
            label: 'Section',
            category: 'Basic',
            content: `<section style="padding: 80px 24px; max-width: 1100px; margin: 0 auto;"></section>`
        });

        bm.add('container', {
            label: 'Container',
            category: 'Basic',
            content: `<div style="max-width: 800px; margin: 0 auto; padding: 0 24px;"></div>`
        });

        bm.add('text', {
            label: 'Text',
            category: 'Basic',
            content: `<p style="font-size: 16px; color: #a1a1aa; line-height: 1.7;">Your text here. Click to edit.</p>`
        });

        bm.add('heading', {
            label: 'Heading',
            category: 'Basic',
            content: `<h2 style="font-size: 40px; font-weight: 800; color: #fff; margin-bottom: 16px;">Your Headline</h2>`
        });

        bm.add('image', {
            label: 'Image',
            category: 'Basic',
            content: { type: 'image' }
        });

        bm.add('link', {
            label: 'Link',
            category: 'Basic',
            content: `<a href="#" style="color: #dc2626;">Link Text</a>`
        });

        bm.add('divider', {
            label: 'Divider',
            category: 'Basic',
            content: `<hr style="border: none; border-top: 1px solid #222; margin: 40px 0;">`
        });

        bm.add('spacer', {
            label: 'Spacer',
            category: 'Basic',
            content: `<div style="height: 60px;"></div>`
        });

        bm.add('custom-code', {
