Output complete valid HTML starting with <!DOCTYPE html>
[THANKYOU_END]
`;
            }

            return basePrompt + pageInstructions + `

═══════════════════════════════════════════════════════════════════════════════════════
CRITICAL OUTPUT REQUIREMENTS
═══════════════════════════════════════════════════════════════════════════════════════
- Output COMPLETE, VALID HTML starting with <!DOCTYPE html>
- Include ALL CSS in <style> tags within <head> using CSS custom properties
- Include ALL JavaScript in <script> tags before </body>
- Make FULLY RESPONSIVE with breakpoints at 900px and 600px
- Include hover states and transitions (0.3s ease) on all interactive elements
- Use the EXACT accent color: ${color.accent}
- Wrap landing page in [LANDING_START] and [LANDING_END]
- Wrap thank you page in [THANKYOU_START] and [THANKYOU_END]
- This must be PRODUCTION-READY code
- NO placeholder comments - every section has real, compelling copy
- Include smooth scroll: html { scroll-behavior: smooth; }
- Add fadeIn animations: @keyframes fadeInUp, @keyframes fadeInDown
- Every interactive element needs :hover state`;
        }
        
        // ═══════════════════════════════════════════════════════════════════════
        // AUTO-IMPORT FROM COMMAND CENTER
        // ═══════════════════════════════════════════════════════════════════════
        function checkForImportedPages() {
            const landing = localStorage.getItem('fg_imported_landing');
            const thankyou = localStorage.getItem('fg_imported_thankyou');
            const source = localStorage.getItem('fg_imported_source');
            const timestamp = localStorage.getItem('fg_imported_timestamp');
            
            // Check if there's imported content
            if ((landing && landing.length > 100) || (thankyou && thankyou.length > 100)) {
                // Load into fgGeneratedCode
                if (landing && landing.length > 100) {
                    fgGeneratedCode.landing = landing;
                }
                if (thankyou && thankyou.length > 100) {
                    fgGeneratedCode.thankyou = thankyou;
                }
                
                // Set current tab to landing if available, otherwise thankyou
                fgCurrentTab = fgGeneratedCode.landing ? 'landing' : 'thankyou';
                
                // Open the funnel generator modal and show results
                openFunnelGenerator();
                
                // Hide form, show output
                document.getElementById('fgForm').style.display = 'none';
                document.getElementById('fgOutput').classList.add('active');
                
                // Render tabs and preview
                renderFgTabs();
                
                // Show notification
                if (source) {
                    showStatus(`✓ Loaded pages from "${source}"`);
                } else {
                    showStatus('✓ Imported pages loaded');
                }
                
                // Clear the import data so it doesn't reload on refresh
                localStorage.removeItem('fg_imported_landing');
                localStorage.removeItem('fg_imported_thankyou');
                localStorage.removeItem('fg_imported_source');
                localStorage.removeItem('fg_imported_timestamp');
            }
        }
        
        // Check for imports on page load
        window.addEventListener('load', function() {
            setTimeout(checkForImportedPages, 500);
        });
    </script>
</body>
</html>
